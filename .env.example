# Core LLM settings
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile

# RAG
RAG_ENABLED=true
RAG_PERSIST_DIR=data/vectorstore

# Rollout strategy (Sprint 4)
# Allowed: shadow | constrained_auto | full_auto
AGENT_ROLLOUT_MODE=constrained_auto
AGENT_AUTONOMY_ENABLED=true

# Governance policy thresholds
GOV_CRITICAL_MIN_CONFIDENCE=0.75
GOV_MEDIUM_RISK_MIN_CONFIDENCE=0.65
GOV_BASELINE_MIN_CONFIDENCE=0.55

# Optional benchmark/gate tuning
AGENTIC_GATE_MIN_PLAN_SUCCESS_RATE=0.55
AGENTIC_GATE_MAX_BLOCKED_STEP_RATE=0.45
AGENTIC_GATE_MIN_AUTONOMOUS_COMPLETION_RATE=0.10
AGENTIC_GATE_MIN_FAILURE_RECOVERY_RATE=0.50
